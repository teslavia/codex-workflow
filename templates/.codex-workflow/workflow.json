{
  "version": 1,
  "codex": {
    "enabled": false,
    "command": "codex exec --prompt-file {prompt_file}",
    "cwd": "{repo_root}"
  },
  "stages": [
    {
      "id": "crew_orchestrate",
      "kind": "crewai",
      "description": "Default CrewAI orchestration (planner/coder/tester/reviewer)",
      "prompt_template": "任务目标: {{goal}}\n项目画像: {{project_profile}}\n质量门禁: {{quality_gates}}\n近期经验: {{recent_lessons}}\n输出要求: 先给最小变更方案，再给执行与验证结论。"
    },
    {
      "id": "verify",
      "kind": "shell",
      "description": "Run required quality gates",
      "command_source": "quality_gates.required",
      "commands": []
    }
  ]
}
